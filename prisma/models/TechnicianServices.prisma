model TechnicianService {
  id String @id @default(uuid()) @db.Uuid

  technicianProfileId String @map("technician_profile_id") @db.Uuid
  serviceId           String @map("service_id") @db.Uuid

  price       Decimal @default(0) @db.Decimal(10, 2)
  description String?

  status TechnicianServiceStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  technicianProfile TechnicianProfile @relation(fields: [technicianProfileId],references: [id],onDelete: Cascade)

  service Service @relation(fields: [serviceId],references: [id])

  bookings Booking[]
  /*
one technician cant make same service twice

*/

  @@unique([technicianProfileId, serviceId])

  @@map("technician_services")
}