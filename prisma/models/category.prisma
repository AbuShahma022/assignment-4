model Category {
  id          String         @id @default(uuid()) @db.Uuid
  name        String         @unique
  description String?
  icon        String?
  status      CategoryStatus @default(ACTIVE)

  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  services        Service[]
  serviceRequests ServiceRequest[]

 
  @@map("categories")
}